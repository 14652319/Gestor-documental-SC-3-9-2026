# ==========================================
# 📧 CONFIGURACIÓN DE CORREO ELECTRÓNICO (Flask-Mail)
# ==========================================
# OPCIÓN 1: Gmail (requiere 2FA y contraseña de aplicación)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=gestordocumentalsc01@gmail.com
MAIL_PASSWORD=tu_contraseña_aplicacion_aqui
MAIL_DEFAULT_SENDER=gestordocumentalsc01@gmail.com
MAIL_REPLY_TO=

# Para Gmail: https://myaccount.google.com/apppasswords

# OPCIÓN 2: Outlook/Office 365
# MAIL_SERVER=smtp-mail.outlook.com (o smtp.office365.com para corporativo)
