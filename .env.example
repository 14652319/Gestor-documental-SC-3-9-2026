# ==========================================
# 🤖 TELEGRAM BOT (Sistema de Comandos de Administración)
# ==========================================
# Bot Token: Obtener desde @BotFather en Telegram
# 1. Abre Telegram y busca @BotFather
# 2. Envía /newbot y sigue instrucciones
# 3. Copia el token que te da (formato: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=8132808615:AAFU-StA-ujNN-5bm_5UQLW_IHXuFEwcW38

# Chat ID: Tu ID de usuario o grupo de Telegram
# Obtener tu Chat ID:
# 1. Busca @userinfobot en Telegram
# 2. Envía /start
# 3. Copia el número que te muestra (solo números)
TELEGRAM_CHAT_ID=7602447172

# Comandos disponibles:
# /desbloquear [IP] - Desbloquear IP bloqueada (ej: /desbloquear 192.168.1.100)
# /ayuda - Ver todos los comandos disponibles
#
# Próximos comandos: /bloquear, /whois, /usuarios_activos, /backup_ahora
# Ver TELEGRAM_BOT_ROADMAP.md para roadmap completo (45+ comandos planeados)
#
# Configurar webhook (solo para producción con dominio público):
# curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#      -d "url=https://tudominio.com/api/telegram/webhook"
#
# Para desarrollo local: Los comandos funcionan sin webhook

# ==========================================
# 📁 DIRECTORIOS BASE
# ==========================================
PROJECT_ROOT=D:/Usuario/Gestor_Login_Seguro/Gestor_Login_Seguro
TEMPLATES_FOLDER=templates
STATIC_FOLDER=static
LOG_DIR=logs
SQL_DIR=sql

# ==========================================
# 👥 CONFIGURACIÓN DE USUARIOS
# ==========================================
# Límite máximo de usuarios por tercero
MAX_USUARIOS_POR_TERCERO=5

# NITs que no tienen restricción de usuarios (administradores internos)
NITS_ESPECIALES_SIN_LIMITE=805028041,805013653

# ==========================================
# 🔐 VALIDACIÓN DEL SISTEMA
# ==========================================
# Habilitar verificación de configuración
LICENSE_ENFORCE=True

# Archivo de configuración del sistema
LICENSE_FILE=license.lic

# Periodo de evaluación (en días)
LICENSE_GRACE_DAYS=5475
